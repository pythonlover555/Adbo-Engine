# Copy to .env and fill in. .env is git-ignored.
BASE_URL=https://example.com
REQUEST_DELAY=1.0
USER_AGENT=YC-Search-Engine/0.1 (+https://example.com)

# --- Co-founder filter server (server/) ---
# LLM key used by the evaluation server (server/llm.py). The browser
# extension never sees this — it only talks to http://localhost:8791.
# Default provider is Google Gemini's free endpoint: get a key (no credit
# card) at https://aistudio.google.com/apikey
YCENG_LLM_API_KEY=...your-gemini-key-here...

# Optional overrides (defaults shown).
# YCENG_PORT=8791
# Provider endpoint + model (default = Gemini free). See server/config.py
# for Groq / Ollama / OpenAI presets.
# YCENG_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# YCENG_LLM_MODEL=gemini-2.5-flash
# YCENG_FUNDING_MIN_USD=100000
# YCENG_ALLOWED_REGIONS=United States,Canada
